NODE_ENV=development
APP_NAME=Stilos
APP_FULL_NAME=Stilos - Moda y Estilo

# ══════════════════════════════════════════════════════════
# BASE DE DATOS
# ══════════════════════════════════════════════════════════

# ── PRODUCCIÓN (Render + Neon) ────────────────────────────
# ✅ Cargar en Render como variable de entorno
# ✅ Si DB_SSL=true no hace falta cargar DB_HOST/PORT/NAME/USER/PASS
#
# Neon → Dashboard → tu proyecto → Connection Details → "Pooled connection"
# Seleccionar: Prisma / Node.js / psql → copiar la connection string completa
# Formato: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ✅ true en producción con Neon (exige SSL)
# ⚠️ Si queda en false con Neon → la conexión rechaza aunque DATABASE_URL sea correcta
DB_SSL=false

# ✅ Schema de PostgreSQL — se crea automáticamente al arrancar
DB_SCHEMA=StilosSchema

# ── DESARROLLO LOCAL (PostgreSQL local) ──────────────────
# ❌ NO cargar en Render si ya tenés DATABASE_URL configurado
# ⚠️ Si estas vars están presentes, pisan DATABASE_URL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=StilosDB
DB_USER=postgres
DB_PASS=

# ── Puerto ────────────────────────────────────────────────
# ❌ NO cargar en Render (lo inyecta automáticamente)
PORT=3001

# ══════════════════════════════════════════════════════════
# JWT
# ══════════════════════════════════════════════════════════
# ✅ Cargar en Render
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_ESTE_SECRETO
JWT_EXPIRES_IN=8h
RESET_TOKEN_EXPIRES_MINUTES=30

# ══════════════════════════════════════════════════════════
# ADMIN
# ══════════════════════════════════════════════════════════
# ✅ Cargar en Render
# El super admin se crea automáticamente con password "Admin123*"
# Cambiar la contraseña desde el panel admin después del primer login
SUPER_ADMIN_EMAIL=admin@stilos.com
# ✅ Cargar en Render
SEED_SECRET=CAMBIAR_ESTE_SECRETO

# ══════════════════════════════════════════════════════════
# SMTP
# ══════════════════════════════════════════════════════════
# ✅ Cargar en Render (mismo valor que local)
# Gmail: activar App Password en myaccount.google.com/apppasswords
# Si SMTP_USER está vacío, el servidor arranca igual (reset de password no envía mails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Stilos <correo@gmail.com>"

# ══════════════════════════════════════════════════════════
# URLs — CORS y frontend
# ══════════════════════════════════════════════════════════
# ✅ Cargar en Render con la URL exacta del frontend en Vercel
# ⚠️ CORS_ORIGIN debe coincidir EXACTAMENTE con el origen del browser (sin barra final)
# ⚠️ Vercel asigna el dominio definitivo en: proyecto → Settings → Domains
# ⚠️ Usar el dominio fijo, NO el dominio de deployment (cambia con cada push)
# Local:      FRONTEND_URL=http://localhost:5173
# Producción: FRONTEND_URL=https://stilos.vercel.app
FRONTEND_URL=http://localhost:5173
# Local:      CORS_ORIGIN=http://localhost:5173
# Producción: CORS_ORIGIN=https://stilos.vercel.app
CORS_ORIGIN=http://localhost:5173

# ══════════════════════════════════════════════════════════
# CLOUDINARY
# ══════════════════════════════════════════════════════════
# ✅ Cargar en Render (mismo valor que local)
# Obtener en: console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ══════════════════════════════════════════════════════════
# OTROS
# ══════════════════════════════════════════════════════════
TZ=America/Argentina/Cordoba

# ══════════════════════════════════════════════════════════
# RESUMEN — qué cargar en cada servicio
# ══════════════════════════════════════════════════════════
#
# RENDER (backend):
#   NODE_ENV=production
#   APP_NAME, APP_FULL_NAME
#   DATABASE_URL   (Neon connection string)
#   DB_SSL=true
#   DB_SCHEMA
#   JWT_SECRET, JWT_EXPIRES_IN, RESET_TOKEN_EXPIRES_MINUTES
#   SUPER_ADMIN_EMAIL, SEED_SECRET
#   SMTP_HOST, SMTP_PORT, SMTP_SECURE, SMTP_USER, SMTP_PASS, SMTP_FROM
#   FRONTEND_URL   (https://stilos.vercel.app)
#   CORS_ORIGIN    (https://stilos.vercel.app)
#   CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
#   TZ
#   ⚠️ NO cargar: PORT, DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASS
#
# VERCEL (frontend):
#   VITE_API_URL=https://stilos-backend.onrender.com/api
#   VITE_MP_PUBLIC_KEY  (solo si enablePayments: true)
#
# NEON:
#   No requiere variables propias — solo pegar la connection string en DATABASE_URL
