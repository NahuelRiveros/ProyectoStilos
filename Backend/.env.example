NODE_ENV=development
APP_NAME=MiApp
APP_FULL_NAME=Mi Aplicación

# ══════════════════════════════════════════════════════════
# BASE DE DATOS
# ══════════════════════════════════════════════════════════

# ✅ PRODUCCIÓN (Render) — pegar la URL COMPLETA que genera Render al crear la DB
# Formato: postgresql://usuario:contraseña@host/nombre_db
# ⚠️  Render → PostgreSQL service → "Internal Database URL" (NO la External)
# ⚠️  Pegar toda la cadena, no solo el hostname (dpg-xxx no es suficiente)
DATABASE_URL=

# ✅ Render — DEBE ser true en producción (Render exige SSL)
# ⚠️  Si queda en false, la conexión falla aunque DATABASE_URL sea correcta
DB_SSL=false

# ✅ Nombre del schema de PostgreSQL (se crea automáticamente si no existe)
DB_SCHEMA=public

# ── Solo desarrollo local ─────────────────────────────────
# ❌ NO cargar en Render — si están presentes pisan la configuración
# ❌ y el servidor intenta conectar como "postgres"@"localhost" ignorando DATABASE_URL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mi_db
DB_USER=postgres
DB_PASS=

# ── Puerto ────────────────────────────────────────────────
# ❌ NO cargar en Render (lo inyecta automáticamente)
PORT=3001

# ══════════════════════════════════════════════════════════
# JWT
# ══════════════════════════════════════════════════════════
# ✅ Render — generar con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_ESTE_SECRETO
JWT_EXPIRES_IN=8h
RESET_TOKEN_EXPIRES_MINUTES=30

# ══════════════════════════════════════════════════════════
# ADMIN
# ══════════════════════════════════════════════════════════
# ✅ El admin se crea automáticamente al arrancar con password "Admin123*"
# Cambiar la contraseña desde el panel admin después del primer login
SUPER_ADMIN_EMAIL=admin@sistema.com
SEED_SECRET=CAMBIAR_ESTE_SECRETO

# ══════════════════════════════════════════════════════════
# SMTP
# ══════════════════════════════════════════════════════════
# ✅ Render — mismo valor que local
# Con Gmail usar App Password: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mi App <correo@gmail.com>"

# ══════════════════════════════════════════════════════════
# URLs — CORS y frontend
# ══════════════════════════════════════════════════════════
# ✅ Render — DEBE ser la URL exacta del frontend en producción
# ⚠️  Vercel asigna el dominio definitivo en: proyecto → Settings → Domains
# ⚠️  El dominio de deployment (xxx-git-main-yyy.vercel.app) cambia con cada push
# ⚠️  Usar siempre el dominio fijo (ej: mi-app.vercel.app)
# ⚠️  Si CORS_ORIGIN no coincide EXACTAMENTE con el origen del browser → error CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ══════════════════════════════════════════════════════════
# CLOUDINARY
# ══════════════════════════════════════════════════════════
# ✅ Render — mismo valor que local
# Obtener en: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ══════════════════════════════════════════════════════════
# OTROS
# ══════════════════════════════════════════════════════════
TZ=America/Argentina/Cordoba
