# ══════════════════════════════════════════════════════════
# DESARROLLO LOCAL
# ══════════════════════════════════════════════════════════
NODE_ENV=development
APP_NAME=Stilos
APP_FULL_NAME=Stilos - Moda y Estilo

DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_NAME=StilosDB
DB_USER=postgres
DB_PASS=

DB_SSL=false
DB_SCHEMA=StilosSchema

PORT=3001

JWT_SECRET=GENERAR_CON_node_-e_crypto.randomBytes(32).toString(hex)
JWT_EXPIRES_IN=8h
RESET_TOKEN_EXPIRES_MINUTES=30

SUPER_ADMIN_EMAIL=tu@email.com
SEED_SECRET=setup_stilos_2026

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Stilos <correo@gmail.com>"

FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

TZ=America/Argentina/Cordoba


# ══════════════════════════════════════════════════════════
# PRODUCCIÓN — copiar estas vars en Render (Environment)
