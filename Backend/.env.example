NODE_ENV=development
APP_NAME=MiApp
APP_FULL_NAME=Mi Aplicación

# ══════════════════════════════════════════════════════════
# BASE DE DATOS
# ══════════════════════════════════════════════════════════

# ✅ PRODUCCIÓN (Render) — pegar la URL que genera Render al crear la DB
# Formato: postgresql://usuario:contraseña@host:5432/nombre_db
DATABASE_URL=

# ✅ Render — cambiar a true en producción
DB_SSL=false

# ✅ Nombre del schema de PostgreSQL (se crea automáticamente si no existe)
DB_SCHEMA=public

# ── Solo desarrollo local ─────────────────────────────────
# ❌ NO cargar en Render (con DATABASE_URL no son necesarias)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mi_db
DB_USER=postgres
DB_PASS=

# ── Puerto ────────────────────────────────────────────────
# ❌ NO cargar en Render (lo inyecta automáticamente)
PORT=3001

# ══════════════════════════════════════════════════════════
# JWT
# ══════════════════════════════════════════════════════════
# ✅ Render — generar con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_ESTE_SECRETO
JWT_EXPIRES_IN=8h
RESET_TOKEN_EXPIRES_MINUTES=30

# ══════════════════════════════════════════════════════════
# ADMIN
# ══════════════════════════════════════════════════════════
# ✅ Render — email del super admin creado al arrancar (protegido de eliminación)
SUPER_ADMIN_EMAIL=admin@sistema.com
# ✅ Render — token para el endpoint POST /api/auth/seed-admin
SEED_SECRET=CAMBIAR_ESTE_SECRETO

# ══════════════════════════════════════════════════════════
# SMTP
# ══════════════════════════════════════════════════════════
# ✅ Render — mismo valor que local
# Con Gmail usar App Password: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mi App <correo@gmail.com>"

# ══════════════════════════════════════════════════════════
# URLs
# ══════════════════════════════════════════════════════════
# ✅ Render — cambiar por la URL real del frontend en producción
# Ejemplo: https://mi-app.vercel.app
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ══════════════════════════════════════════════════════════
# CLOUDINARY
# ══════════════════════════════════════════════════════════
# ✅ Render — mismo valor que local
# Obtener en: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ══════════════════════════════════════════════════════════
# OTROS
# ══════════════════════════════════════════════════════════
# ✅ Render — mismo valor
TZ=America/Argentina/Cordoba
