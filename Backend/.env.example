NODE_ENV=development
PORT=3001

APP_NAME=MiApp
APP_FULL_NAME=Mi Aplicación

# Base de datos — local: usar variables individuales; producción: Render inyecta DATABASE_URL
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mi_db
DB_SCHEMA=public
DB_USER=postgres
DB_PASS=
DB_SSL=false

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_ESTE_SECRETO
JWT_EXPIRES_IN=8h

RESET_TOKEN_EXPIRES_MINUTES=30

# Email del super admin creado automáticamente en el arranque (protegido de eliminación via API)
SUPER_ADMIN_EMAIL=admin@sistema.com

# Seed de admin por token secreto (POST /api/auth/seed-admin con header x-seed-token)
SEED_SECRET=CAMBIAR_ESTE_SECRETO

# SMTP — con Gmail usar App Password (myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mi App <correo@gmail.com>"

# URLs
FRONTEND_URL=http://localhost:5173
# En producción: CORS_ORIGIN=https://mi-app.vercel.app
# Múltiples orígenes: CORS_ORIGIN=https://app.vercel.app,https://admin.vercel.app
CORS_ORIGIN=http://localhost:5173

TZ=America/Argentina/Cordoba
