# ══════════════════════════════════════════════════════════════
# API — URL del backend
# ══════════════════════════════════════════════════════════════

# ✅ Vercel — URL del backend en Render + /api al final (obligatorio)
# ⚠️  Sin el /api las rutas no funcionan (ej: /auth/login en vez de /api/auth/login)
# ⚠️  En desarrollo dejar vacío (usa localhost:3001/api por defecto)
# Producción: VITE_API_URL=https://mi-backend.onrender.com/api
VITE_API_URL=

# ══════════════════════════════════════════════════════════════
# MERCADO PAGO
# ══════════════════════════════════════════════════════════════

# ✅ Vercel — solo necesario cuando cartConfig.enablePayments: true
# ⚠️  Usar la PUBLIC KEY (nunca la secret key en el frontend)
# Obtener en: https://www.mercadopago.com.ar/settings/account/credentials
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
