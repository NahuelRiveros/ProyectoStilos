# ══════════════════════════════════════════════════════════════
# API — URL del backend
# ══════════════════════════════════════════════════════════════

# ✅ Cargar en Vercel → Settings → Environment Variables
# ⚠️ Sin el /api las rutas no funcionan
# ⚠️ Usar el dominio fijo de Render, no el que cambia con cada deploy
# Local:      dejar vacío (usa http://localhost:3001/api por defecto)
# Producción: VITE_API_URL=https://stilos-backend.onrender.com/api
VITE_API_URL=

# ══════════════════════════════════════════════════════════════
# MERCADO PAGO
# ══════════════════════════════════════════════════════════════

# ✅ Cargar en Vercel solo si cartConfig.enablePayments: true (modo ECOMMERCE)
# La tienda está en modo CATALOG_WHATSAPP → esta var no se usa
# ⚠️ Usar siempre la PUBLIC KEY — nunca la secret key en el frontend
# Obtener en: mercadopago.com.ar/settings/account/credentials → Credenciales de prueba / producción
VITE_MP_PUBLIC_KEY=
